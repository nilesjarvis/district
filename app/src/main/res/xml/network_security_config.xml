<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.178.32</domain>
    </domain-config>
    <!-- Loopback only, for on-device instrumentation tests; traffic never leaves the device. -->
